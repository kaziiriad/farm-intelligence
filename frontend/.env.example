VITE_API_BASE_URL=https://kenya-farm-weather-api.onrender.com

# Optional server-side backend URL for TanStack Start SSR/server functions.
# Use the same Render URL unless you have a private/internal backend URL.
API_INTERNAL_BASE_URL=https://kenya-farm-weather-api.onrender.com
